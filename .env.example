# ====================================================
# CineBook - Environment Variables Template
# ====================================================
# Copy this file and rename:
#   .env.local       → for local development
#   .env.production  → for production deployment
#
# Start with:
#   node start-all.js                  → loads .env.local
#   NODE_ENV=production node start-all.js → loads .env.production
# ====================================================

# --- Database ---
# Local (Docker):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=movieticket
DB_USER=postgres
DB_PASSWORD=postgres
# Cloud (Neon): uncomment and set DATABASE_URL instead
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# --- RabbitMQ ---
# Local (Docker):
RABBITMQ_URL=amqp://guest:guest@localhost:5672
# Cloud (CloudAMQP): replace with your amqps:// URL

# --- Redis ---
# Local (Docker):
REDIS_URL=redis://localhost:6379
# Cloud (Upstash): replace with your rediss:// URL

# --- Email (pick one) ---
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=your-email@example.com
RESEND_API_KEY=your-resend-api-key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
